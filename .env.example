# ========================================================
# Expoint ADV - Notification Services Configuration
# ========================================================
# 1. Telegram Bot (Create via @BotFather)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-chat-or-channel-id"

# 2. Email Notifications (SMTP Server)
SMTP_HOST="smtp.yandex.ru"
SMTP_PORT="465"
SMTP_USER="robot@expoint-adv.ru"
SMTP_PASS="your-app-password"
NOTIFICATION_EMAIL="sales@expoint-adv.ru"

# 3. CRM Integration (AmoCRM / Bitrix24 / Custom)
CRM_WEBHOOK_URL="https://your-crm-webhook.com/lead"

# ========================================================
# Analytics
# ========================================================
NEXT_PUBLIC_GA_ID="G-XYZ1234567"
NEXT_PUBLIC_POSTHOG_KEY="phc_xxx"
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
LOG_INGRESS_SECRET="replace-me"
ADMIN_API_KEY="replace-me"

# ========================================================
# Bot Security & Runtime Toggles
# ========================================================
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAA..."
TURNSTILE_SECRET_KEY="0x4AAAA..."
ENABLE_STRICT_HTTPS="false"
ENABLE_HSTS="false"
NBLLM_RUNTIME_DISABLED="false"
# ========================================================
# Database (Postgres - Localized in RF)
# ========================================================
POSTGRES_URL="postgresql://user:password@host:5432/db"
