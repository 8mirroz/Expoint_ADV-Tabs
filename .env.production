# Required by Caddy in docker-compose.yml
DOMAIN=example.com
ACME_EMAIL=ops@example.com

# App runtime
NODE_ENV=production

# Notification integrations
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-or-channel-id

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=robot@expoint-adv.ru
SMTP_PASS=your-app-password
NOTIFICATION_EMAIL=sales@expoint-adv.ru

CRM_WEBHOOK_URL=https://your-crm-webhook.com/lead
NEXT_PUBLIC_GA_ID=G-XYZ1234567

# If used by app/runtime
GEMINI_API_KEY=your-gemini-api-key
